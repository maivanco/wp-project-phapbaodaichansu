ENVIRONMENT=local
PROJECT_NAME=pbdcs
# Wordpress Database configs
# Docker Compose DNS name of the MySQL service (hostname `db` is also provided as a network alias)
WORDPRESS_DB_HOST=db
WORDPRESS_DB_USER=default_user
WORDPRESS_DB_PASSWORD=default_password
WORDPRESS_DB_NAME=wp_db
WORDPRESS_DB_ROOT_PASSWORD=default_root_password
